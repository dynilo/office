APP_NAME="AI Office OS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=office
DB_USERNAME=postgres
DB_PASSWORD=
DB_SEARCH_PATH=public
DB_SSLMODE=prefer
DB_ENFORCE_POSTGRESQL=true
DB_REQUIRE_SSL_IN_PRODUCTION=true

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
DOCUMENT_STORAGE_DISK=local
DOCUMENT_STORAGE_PREFIX=documents
DOCUMENT_STORAGE_ALLOWED_DISKS=local,s3
ARTIFACT_STORAGE_DISK=local
ARTIFACT_STORAGE_PREFIX=artifacts
ARTIFACT_STORAGE_ALLOWED_DISKS=local,s3,private
RUNTIME_STORAGE_DISALLOW_PUBLIC_IN_PRODUCTION=true
QUEUE_CONNECTION=redis
QUEUE_ENFORCE_REDIS_IN_PRODUCTION=true
QUEUE_REQUIRE_REDIS_BLOCK_FOR=true

CACHE_STORE=redis
CACHE_PREFIX=ai-office-os
CONTEXT_RETRIEVAL_TOP_K=3
CONTEXT_RETRIEVAL_MAX_DISTANCE=0.8

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_BLOCK_FOR=5
REDIS_QUEUE_AFTER_COMMIT=true
REDIS_BROADCAST_CONNECTION=default
RUNTIME_EXECUTION_QUEUE_CONNECTION=redis
RUNTIME_EXECUTION_QUEUE=executions
RUNTIME_EXECUTION_TRIES=3
RUNTIME_EXECUTION_BACKOFF_SECONDS=5,30,120
WORKER_EXECUTION_NAME=ai-office-execution-worker
WORKER_QUEUE_CONNECTION=redis
WORKER_QUEUE=executions
WORKER_TRIES=3
WORKER_BACKOFF_SECONDS=5,30,120
WORKER_SLEEP_SECONDS=3
WORKER_TIMEOUT_SECONDS=60
WORKER_MAX_JOBS=500
WORKER_MAX_TIME_SECONDS=3600
WORKER_MEMORY_MB=256
WORKER_STOP_WHEN_EMPTY=false
WORKER_SUPERVISION_DRIVER=none
WORKER_REQUIRE_SUPERVISION_IN_PRODUCTION=false
WORKER_SUPERVISOR_STATUS_PATH=
WORKER_PROCESS_SNAPSHOT_PATH=

LLM_PROVIDER=openai_compatible
LLM_PROVIDER_FAILOVER_ORDER=openai_compatible,openai_compatible_secondary
LLM_PROVIDER_FAILOVER_RETRIABLE_ONLY=true
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_MODEL=gpt-5
OPENAI_TIMEOUT_SECONDS=30
OPENAI_RETRY_TIMES=2
OPENAI_RETRY_SLEEP_MS=200
OPENAI_STORE=false
OPENAI_SECONDARY_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_SECONDARY_API_KEY=
OPENAI_SECONDARY_ORGANIZATION=
OPENAI_SECONDARY_PROJECT=
OPENAI_SECONDARY_MODEL=gpt-5
OPENAI_SECONDARY_TIMEOUT_SECONDS=30
OPENAI_SECONDARY_RETRY_TIMES=2
OPENAI_SECONDARY_RETRY_SLEEP_MS=200
OPENAI_SECONDARY_STORE=false
COST_TRACKING_ENABLED=true
COST_TRACKING_CURRENCY=USD
OPENAI_COST_INPUT_PER_MILLION_TOKENS=0
OPENAI_COST_OUTPUT_PER_MILLION_TOKENS=0
OPENAI_SECONDARY_COST_INPUT_PER_MILLION_TOKENS=0
OPENAI_SECONDARY_COST_OUTPUT_PER_MILLION_TOKENS=0
EMBEDDING_PROVIDER=openai_compatible
# Set EMBEDDING_PROVIDER=null only for explicit non-production fallback mode.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_TIMEOUT_SECONDS=30
OPENAI_EMBEDDING_RETRY_TIMES=2
OPENAI_EMBEDDING_RETRY_SLEEP_MS=200
PROMPT_VERSION=2026-04-23.v1
PROMPT_TEMPLATE_STRATEGY=agent-role-template
PROMPT_SCHEMA_VERSION=1

MEMORY_EMBEDDING_DIMENSIONS=1536
MEMORY_VECTOR_DISTANCE=cosine
PGVECTOR_EXTENSION_NAME=vector
PGVECTOR_REQUIRE_IN_PRODUCTION=false
PGVECTOR_INDEX_ENABLED=true
PGVECTOR_INDEX_METHOD=hnsw
PGVECTOR_INDEX_NAME=knowledge_items_embedding_hnsw_idx

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
